# ========================================
# EmailJS Configuration
# ========================================
# Get these values from https://www.emailjs.com/

# Your EmailJS Public Key (from Account > General)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Your EmailJS Service ID (from Email Services)
VITE_EMAILJS_SERVICE_ID=your_service_id_here

# ========================================
# Inquiry Email Templates
# ========================================

# Admin receives inquiry details
VITE_EMAILJS_TEMPLATE_ID=template_inquiry_admin

# User receives inquiry confirmation
VITE_EMAILJS_CONFIRMATION_TEMPLATE_ID=template_inquiry_user

# ========================================
# Purchase Flow Email Templates
# ========================================

# Order Success - User Email (Order Confirmation)
# Sent after successful payment
VITE_EMAILJS_ORDER_SUCCESS_USER_TEMPLATE=template_order_success_user

# Order Success - Admin Email (New Order Notification)
# Sent after successful payment
VITE_EMAILJS_ORDER_SUCCESS_ADMIN_TEMPLATE=template_order_success_admin

# Payment Failed - User Email
# Sent when Razorpay payment fails
VITE_EMAILJS_PAYMENT_FAILED_TEMPLATE=template_payment_failed

# COD Order - User Email (COD Order Confirmation)
# Sent when user places COD order
VITE_EMAILJS_COD_ORDER_USER_TEMPLATE=template_cod_order_user

# COD Order - Admin Email (New COD Order Notification)
# Sent when user places COD order
VITE_EMAILJS_COD_ORDER_ADMIN_TEMPLATE=template_cod_order_admin

# ========================================
# Email Recipients
# ========================================

# Admin email (where all notifications will be sent)
VITE_RECIPIENT_EMAIL=admin@company.com

# ========================================
# Payment Configuration
# ========================================

# Payment Backend API URL
VITE_PAYMENT_API_URL=http://localhost:5000

# Razorpay Key ID (from Razorpay Dashboard)
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# ========================================
# Setup Instructions
# ========================================
# 
# 1. Create EmailJS account at https://www.emailjs.com/
# 2. Create an email service (Gmail, Outlook, etc.)
# 3. Create 7 email templates with the IDs shown above
# 4. Copy your Public Key and Service ID
# 5. Replace all placeholder values in this file
# 6. Rename this file to .env
# 7. Restart your development server
# 
# For detailed setup instructions, see:
# - Amazon readme files/EMAILJS_QUICK_SETUP.md
# - Amazon readme files/EMAILJS_COMPLETE_SYSTEM.md
# 
# ========================================
