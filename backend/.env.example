# Razorpay API Keys
# Get these from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Instructions:
# 1. Copy this file and rename it to .env
# 2. Replace all placeholder values with actual values
# 3. Never commit the .env file to Git (it's in .gitignore)
# 4. For production, use live Razorpay keys and update NODE_ENV to 'production'

# For Production (uncomment and update when going live):
# RAZORPAY_KEY_ID=rzp_live_YOUR_LIVE_KEY_ID
# RAZORPAY_KEY_SECRET=YOUR_LIVE_KEY_SECRET
# NODE_ENV=production
# FRONTEND_URL=https://yourdomain.com
