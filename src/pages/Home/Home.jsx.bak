                { icon: Leaf, label: 'Eco-friendly packaging materials', title: sustainabilityPoints[1] },
                { icon: Globe, label: 'Reducing environmental impact', title: sustainabilityPoints[2] },
                { icon: Users, label: 'Supporting local communities', title: sustainabilityPoints[3] },
