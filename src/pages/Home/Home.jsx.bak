                      </div>
                      <div>
                        <h4 className="text-lg font-semibold text-gray-900 mb-2">{point}</h4>
                        <p className="text-gray-600">
                          {index === 0 && 'Using cutting-edge fermentation technology for maximum nutrient content'}
                          {index === 1 && 'Every batch tested in certified laboratories for quality assurance'}
                          {index === 2 && 'Constantly improving our formulas based on latest agricultural research'}
                          {index === 3 && 'Direct feedback from farmers helps us refine our products'}
                        </p>
